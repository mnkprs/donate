# Philotimo — local environment variables
# Copy to .env.local and fill in.

# Which network to read receipts from.
# - "base"        → Base mainnet (production receipts)
# - "base-sepolia" → Base Sepolia testnet (development)
NEXT_PUBLIC_CHAIN=base-sepolia

# RPC endpoints. Public endpoints work for development.
# Replace with authenticated Alchemy/QuickNode URLs before any real load.
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ──────────────────────────────────────────────────────────────────────────
# Epic 3 — Fiat-to-crypto on-ramp (server-only; never NEXT_PUBLIC_*)
# ──────────────────────────────────────────────────────────────────────────

# Stripe Crypto Onramp (Sandbox keys for dev; live keys for prod).
# Dashboard → Developers → API keys. Webhook secret comes from the
# webhook endpoint configuration for `crypto.onramp_session.*` events.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_ONRAMP_WEBHOOK_SECRET=whsec_replace_me

# Vercel KV / Upstash Redis REST credentials.
# `vercel env pull` populates these from the Vercel integration.
KV_REST_API_URL=https://example-kv.upstash.io
KV_REST_API_TOKEN=replace_me

# Philotimo router contract on Base Sepolia.
# Epic 4 deploys the real contract; until then, paste a placeholder 0x[40 hex]
# and the server env validator will accept it. Production must reject the
# zero address explicitly (added in a later phase).
ROUTER_ADDRESS_BASE_SEPOLIA=0x0000000000000000000000000000000000000000

# USDC on Base Sepolia. Canonical address from Circle's docs.
USDC_CONTRACT_BASE_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e
